# Maps JavaScript API (Street View in the browser; exposed to client)
NEXT_PUBLIC_MAPS_JAVASCRIPT_API_KEY=your_maps_javascript_api_key_here

# Reviews are read from the local SQLite corpus in data/db/would-not-recommend.db.
# Populate it with: npm run import:reviews -- data/review-corpus.json

# TTS engine:
# - piper: local Piper TTS through a persistent .venv-piper worker (default)
# - kokoro: local Kokoro TTS through .venv-kokoro
TTS_ENGINE=piper
# Set false only to diagnose worker issues; one-shot Piper is slower.
PIPER_PERSISTENT_WORKER=true
KOKORO_VOICE=af_heart
KOKORO_LANG=a
KOKORO_SPEED=1

NEXT_PUBLIC_KIOSK_MODE=false
NEXT_PUBLIC_CITY_TOUR=false

# Production presentation launcher (`npm run start:kiosk` or `npm start`).
# Leave unset for the default two-window setup: /bot and /terminal.
# GSV_KIOSK=0 disables browser launch; GSV_KIOSK=1 forces it off Windows.
# GSV_KIOSK_URLS=/bot,/terminal
# GSV_KIOSK_MODE=app
# Automatic Windows placement expects a primary 4K bot display and a
# non-primary 1080p terminal display. Route-order override example:
# GSV_KIOSK_BOUNDS=0,0,3840,2160;-1920,540,1920,1080
# GSV_KIOSK_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Experimental: Three.js CCTV-style overlay on /bot (Street View). "true" to enable.
NEXT_PUBLIC_BOT_CCTV_OVERLAY=false

# Optional UI-only gate for /admin (leave empty for open local dev)
NEXT_PUBLIC_ADMIN_PASSWORD=1337s
