# Maps JavaScript API (Street View in the browser — exposed to client)
NEXT_PUBLIC_MAPS_JAVASCRIPT_API_KEY=your_maps_javascript_api_key_here

# Optional: /api/places (and PLACES fallback). HUD city/country is offline GeoNames — not Google Geocoding.
GEOCODING_API_KEY=your_geocoding_api_key_here
PLACES_API_KEY=your_places_api_key_here

NEXT_PUBLIC_KIOSK_MODE=false

# Experimental: Three.js CCTV-style overlay on /bot (Street View). "true" to enable.
NEXT_PUBLIC_BOT_CCTV_OVERLAY=false

# Optional UI-only gate for /admin (leave empty for open local dev)
NEXT_PUBLIC_ADMIN_PASSWORD=1337s
